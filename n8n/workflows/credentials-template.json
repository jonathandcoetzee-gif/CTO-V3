{
  "name": "Revenue OS — n8n Credentials Template",
  "description": "Reference template for all n8n credential types used by the Revenue OS pipelines. Copy and fill in values via the n8n UI.",
  "credentials": {
    "httpRequest": {
      "type": "httpRequest",
      "notes": "Base HTTP credential used by all pipeline nodes to call ACE webhooks.",
      "fields": {
        "url": "http://ace-core:3001",
        "authentication": "none"
      }
    },
    "openAi": {
      "type": "openAi",
      "notes": "Used by ACE Core for LLM inference (topic generation, content writing).",
      "fields": {
        "apiKey": "$OPENAI_API_KEY"
      }
    },
    "googleOAuth2": {
      "type": "googleOAuth2",
      "notes": "Used for YouTube Data API v3 video uploads.",
      "fields": {
        "clientId": "(from Google Cloud Console)",
        "clientSecret": "(from Google Cloud Console)",
        "oauthTokenData": "$YOUTUBE_OAUTH"
      }
    },
    "stripeApi": {
      "type": "stripeApi",
      "notes": "Used to verify payments and create checkout sessions.",
      "fields": {
        "secretKey": "$STRIPE_SECRET_KEY",
        "webhookSecret": "$STRIPE_WEBHOOK_SECRET"
      }
    },
    "httpRequestKdp": {
      "type": "httpRequest",
      "notes": "Used to call Amazon KDP API for e-book publication.",
      "fields": {
        "url": "https://kdp.amazon.com/...",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headers": {
          "Authorization": "Bearer $KDP_API_KEY"
        }
      }
    },
    "ethereumRpc": {
      "type": "httpRequest",
      "notes": "Used to call Ethereum RPC for NFT minting transactions.",
      "fields": {
        "url": "$ETH_RPC_URL",
        "authentication": "none"
      }
    },
    "pinata": {
      "type": "httpRequest",
      "notes": "Used to upload NFT metadata and artwork to IPFS.",
      "fields": {
        "url": "https://api.pinata.cloud",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headers": {
          "pinata_api_key": "$PINATA_API_KEY",
          "pinata_secret_api_key": "$PINATA_SECRET"
        }
      }
    },
    "telegram": {
      "type": "telegram",
      "notes": "Used to send pipeline status notifications.",
      "fields": {
        "accessToken": "$TELEGRAM_BOT_TOKEN"
      }
    }
  },
  "env_var_mapping": {
    "$OPENAI_API_KEY": "OPENAI_API_KEY",
    "$YOUTUBE_OAUTH": "YOUTUBE_OAUTH",
    "$STRIPE_SECRET_KEY": "STRIPE_SECRET_KEY",
    "$STRIPE_WEBHOOK_SECRET": "STRIPE_WEBHOOK_SECRET",
    "$KDP_API_KEY": "KDP_API_KEY",
    "$ETH_RPC_URL": "ETH_RPC_URL",
    "$PINATA_API_KEY": "PINATA_API_KEY",
    "$PINATA_SECRET": "PINATA_SECRET",
    "$TELEGRAM_BOT_TOKEN": "TELEGRAM_BOT_TOKEN"
  }
}